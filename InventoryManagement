import java.util.*;
import java.io.*;

class Product {
    String name;
    int quantity;
    double price;

    Product(String name, int quantity, double price) {
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }
}

public class InventoryManagement {

    static final String FILE = "inventory.txt";

    // Save product to file
    static void saveToFile(Product p) {
        try {
            FileWriter fw = new FileWriter(FILE, true);
            fw.write(p.name + "," + p.quantity + "," + p.price + "\n");
            fw.close();
        } catch (IOException e) {
            System.out.println("Error saving data.");
        }
    }

    // Load products from file
    static ArrayList<Product> loadFromFile() {
        ArrayList<Product> list = new ArrayList<>();
        try {
            BufferedReader br = new BufferedReader(new FileReader(FILE));
            String line;
            while ((line = br.readLine()) != null) {
                String[] data = line.split(",");
                list.add(new Product(data[0], Integer.parseInt(data[1]), Double.parseDouble(data[2])));
            }
            br.close();
        } catch (IOException e) {
            // file may not exist first time
        }
        return list;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Product> products = loadFromFile();

        while (true) {
            System.out.println("\n===== INVENTORY MANAGEMENT =====");
            System.out.println("1. Add Product");
            System.out.println("2. View Products");
            System.out.println("3. Search Product");
            System.out.println("4. Update Quantity");
            System.out.println("5. Delete Product");
            System.out.println("6. Exit");
            System.out.print("Enter choice: ");

            int choice;

            if (sc.hasNextInt()) {
                choice = sc.nextInt();
                sc.nextLine();
            } else {
                System.out.println("Invalid input!");
                sc.next();
                continue;
            }

            switch (choice) {
                case 1:
                    System.out.print("Enter name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter quantity: ");
                    int qty = sc.nextInt();

                    System.out.print("Enter price: ");
                    double price = sc.nextDouble();
                    sc.nextLine();

                    Product p = new Product(name, qty, price);
                    products.add(p);
                    saveToFile(p);

                    System.out.println("Product added!");
                    break;

                case 2:
                    if (products.isEmpty()) {
                        System.out.println("No products available.");
                    } else {
                        for (Product prod : products) {
                            System.out.println(prod.name + " | Qty: " + prod.quantity + " | Price: ₹" + prod.price);
                        }
                    }
                    break;

                case 3:
                    System.out.print("Enter product name: ");
                    String search = sc.nextLine();
                    boolean found = false;

                    for (Product prod : products) {
                        if (prod.name.equalsIgnoreCase(search)) {
                            System.out.println("Found: " + prod.name + " | Qty: " + prod.quantity + " | ₹" + prod.price);
                            found = true;
                        }
                    }

                    if (!found) System.out.println("Product not found.");
                    break;

                case 4:
                    System.out.print("Enter product name: ");
                    String update = sc.nextLine();

                    for (Product prod : products) {
                        if (prod.name.equalsIgnoreCase(update)) {
                            System.out.print("Enter new quantity: ");
                            prod.quantity = sc.nextInt();
                            sc.nextLine();
                            System.out.println("Updated!");
                            break;
                        }
                    }
                    break;

                case 5:
                    System.out.print("Enter product name to delete: ");
                    String del = sc.nextLine();

                    products.removeIf(prod -> prod.name.equalsIgnoreCase(del));
                    System.out.println("Deleted if existed.");
                    break;

                case 6:
                    System.out.println("Exiting...");
                    sc.close();
                    return;

                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}

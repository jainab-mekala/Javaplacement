import java.util.Scanner;

class Bookie {
    String name;
    boolean isIssued;
    int days;

    // Constructor
    Bookie(String name) {
        this.name = name;
        this.isIssued = false;
        this.days = 0;
    }
}

public class LibraryManagement {

    static Bookie[] books = new Bookie[10];
    static int count = 0;

    // Add Book
    static void addBook(Scanner sc) {
        if (count == books.length) {
            System.out.println("Library is full!");
            return;
        }

        System.out.print("Enter book name: ");
        String name = sc.nextLine();

        books[count] = new Bookie(name);
        count++;

        System.out.println("Book added successfully!");
    }

    // View Books
    static void viewBooks() {
        System.out.println("\n===== BOOK LIST =====");

        if (count == 0) {
            System.out.println("No books available.");
            return;
        }

        for (int i = 0; i < count; i++) {
            System.out.print((i + 1) + ". " + books[i].name);

            if (books[i].isIssued) {
                System.out.println(" (Issued)");
            } else {
                System.out.println(" (Available)");
            }
        }
    }

    // Issue Book
    static void issueBook(Scanner sc) {
        System.out.print("Enter book name to issue: ");
        String name = sc.nextLine();

        for (int i = 0; i < count; i++) {
            if (books[i].name.equalsIgnoreCase(name)) {

                if (books[i].isIssued) {
                    System.out.println("Book already issued!");
                } else {
                    books[i].isIssued = true;

                    System.out.print("Enter number of days: ");
                    if (sc.hasNextInt()) {
                        books[i].days = sc.nextInt();
                        sc.nextLine();
                        System.out.println("Book issued successfully!");
                    } else {
                        System.out.println("Invalid input for days!");
                        sc.next();
                    }
                }
                return;
            }
        }

        System.out.println("Book not found.");
    }

    // Return Book
    static void returnBook(Scanner sc) {
        System.out.print("Enter book name to return: ");
        String name = sc.nextLine();

        for (int i = 0; i < count; i++) {
            if (books[i].name.equalsIgnoreCase(name)) {

                if (!books[i].isIssued) {
                    System.out.println("Book was not issued.");
                } else {
                    int fine = 0;

                    if (books[i].days > 7) {
                        fine = (books[i].days - 7) * 5;
                    }

                    books[i].isIssued = false;
                    books[i].days = 0;

                    System.out.println("Book returned successfully!");

                    if (fine > 0) {
                        System.out.println("Fine to pay: ₹" + fine);
                    } else {
                        System.out.println("No fine.");
                    }
                }
                return;
            }
        }

        System.out.println("Book not found.");
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n===== LIBRARY MANAGEMENT SYSTEM =====");
            System.out.println("1. Add Book");
            System.out.println("2. View Books");
            System.out.println("3. Issue Book");
            System.out.println("4. Return Book");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");

            int choice;

            if (sc.hasNextInt()) {
                choice = sc.nextInt();
                sc.nextLine();
            } else {
                System.out.println("Invalid input!");
                sc.next();
                continue;
            }

            switch (choice) {
                case 1:
                    addBook(sc);
                    break;
                case 2:
                    viewBooks();
                    break;
                case 3:
                    issueBook(sc);
                    break;
                case 4:
                    returnBook(sc);
                    break;
                case 5:
                    System.out.println("Exiting...");
                    sc.close();
                    return;
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
